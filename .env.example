# Mailgun
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=m.nexpo.vn
MAILGUN_API_URL=https://api.mailgun.net

# Directus (for matching engine)
DIRECTUS_URL=https://app.nexpo.vn
DIRECTUS_ADMIN_TOKEN=your_directus_admin_token_here

# OpenRouter AI (for job matching)
OPENROUTER_API_KEY=your_openrouter_api_key_here
GOOGLE_AI_API_KEY=your-key-from-aistudio.google.com
NOVITA_API_KEY=

# AI Gateway (9router) — DEV ONLY. Leave empty in staging/prod.
# Install: npm install -g 9router && 9router  (runs on port 20128)
# When set, AI calls try gateway first, then fall back to direct providers above.
AI_GATEWAY_URL=
AI_GATEWAY_API_KEY=sk-local
AI_GATEWAY_TEXT_MODEL=gc/gemini-2.5-pro
AI_GATEWAY_CHAT_MODEL=cc/claude-sonnet-4-5

# NexClaude HMAC signing secret for hard-action commit payloads
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
NEXCLAUDE_SIGNING_SECRET=dev-only-insecure-change-in-production
